<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>信息展示页</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #fff;
            font-size: 32px;
            padding: 40px 60px;
            line-height: 3.2;
        }
        .item {
            display: flex;
            align-items: center;
            margin: 12px 0;
        }
        .dot {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 2px solid #aaa;
            margin-right: 20px;
        }
        .label {
            letter-spacing: 12px; /* 文字拉开间距，和原图对齐 */
        }
        .top-bar {
            height: 80px;
            background-color: #323270;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
        }
        .top-line {
            height: 12px;
            background-color: #e8ebf2;
            width: 100%;
            margin-top: 80px;
        }
    </style>
</head>
<body>
    <div class="top-bar"></div>
    <div class="top-line"></div>

    <div style="margin-top: 40px;">
        <div class="item">
            <span class="dot"></span>
            <span class="label">姓　　名：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">性　　别：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">身份证号：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">测试时间：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">测试机构：</span>
        </div>

        <br>

        <div class="item">
            <span class="dot"></span>
            <span class="label">成　　绩：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">等　　级：</span>
        </div>
        <div class="item">
            <span class="dot"></span>
            <span class="label">证书编号：</span>
        </div>
    </div>
</body>
</html>
